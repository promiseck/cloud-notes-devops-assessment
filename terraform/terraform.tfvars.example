project_name     = "cloud-notes"
environment      = "dev"
aws_region       = "eu-west-2"
desired_capacity = 2

# Optional. If blank, Terraform uses the ECR repository it creates.
# container_image = "123456789012.dkr.ecr.eu-west-2.amazonaws.com/cloud-notes:latest"

# Optional after you own a domain and create an ACM certificate.
# domain_name     = "notes.example.com"
# hosted_zone_id  = "Z1234567890"
# certificate_arn = "arn:aws:acm:eu-west-2:123456789012:certificate/..."
